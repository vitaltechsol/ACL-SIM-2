<Window x:Class="ACL_SIM_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ACL_SIM_2"
        mc:Ignorable="d"
        Title="ACL 2.0" Height="600" Width="1000"
        Background="#1e1e1e" Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ACL 2.0" FontSize="20" FontWeight="SemiBold" />

        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,12,0,12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Axis panels bound to ViewModel -->
            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Pitch" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Encoder:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Pitch.EncoderNormalized}" />
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Pitch.TorqueNormalized}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Pitch"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Roll" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Encoder:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Roll.EncoderNormalized}" />
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Roll.TorqueNormalized}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Roll" Click="Button_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Rudder" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Encoder:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Rudder.EncoderNormalized}" />
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Rudder.TorqueNormalized}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Rudder"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Tiller" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Encoder:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Tiller.EncoderNormalized}" />
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Tiller.TorqueNormalized}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Tiller"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Open Setup" Width="120" Height="32" Command="{Binding SetupCommand}" />
        </StackPanel>
    </Grid>
</Window>
