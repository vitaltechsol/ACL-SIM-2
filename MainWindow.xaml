<Window x:Class="ACL_SIM_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ACL_SIM_2"
        mc:Ignorable="d"
        Title="ACL 2.0" Height="600" Width="1000"
        Background="#1e1e1e" Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ACL 2.0" FontSize="20" FontWeight="SemiBold" />

        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,12,0,12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Axis panels bound to ViewModel -->
            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pitch" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Pitch.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" />

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Pitch.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Autopilot (pitch only) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Pitch.AutopilotOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Auto Pilot" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Pitch.ConnectionBrush}" />
                                <TextBlock Text="Encoder" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Pitch.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Pitch.EncoderNormalized}" IsEnabled="{Binding Pitch.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Pitch.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Pitch.TorqueNormalized}" IsEnabled="{Binding Pitch.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Pitch.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Pitch" IsEnabled="{Binding Pitch.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Roll" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Roll.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" />

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Roll.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Autopilot (roll only) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Roll.AutopilotOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Auto Pilot" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Roll.ConnectionBrush}" />
                                <TextBlock Text="Encoder" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Roll.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Roll.EncoderNormalized}" IsEnabled="{Binding Roll.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Roll.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Roll.TorqueNormalized}" IsEnabled="{Binding Roll.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Roll.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Roll" Click="Button_Click" IsEnabled="{Binding Roll.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Rudder" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Rudder.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" />

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Rudder.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Rudder.ConnectionBrush}" />
                                <TextBlock Text="Encoder" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Rudder.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Rudder.EncoderNormalized}" IsEnabled="{Binding Rudder.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Rudder.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Rudder.TorqueNormalized}" IsEnabled="{Binding Rudder.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Rudder.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Rudder" IsEnabled="{Binding Rudder.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tiller" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Tiller.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" />

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tiller.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Tiller.ConnectionBrush}" />
                                <TextBlock Text="Encoder" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Tiller.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Tiller.EncoderNormalized}" IsEnabled="{Binding Tiller.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tiller.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock Text="Torque:" Margin="0,8,0,0" />
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Tiller.TorqueNormalized}" IsEnabled="{Binding Tiller.Enabled}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tiller.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Tiller" IsEnabled="{Binding Tiller.Underlying.Settings.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Open Setup" Width="120" Height="32" Command="{Binding SetupCommand}" />
            <Button Content="Global Settings" Width="140" Height="32" Margin="8,0,0,0" Command="{Binding GlobalSettingsCommand}" />
        </StackPanel>
    </Grid>
</Window>
