<Window x:Class="ACL_SIM_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ACL_SIM_2"
        mc:Ignorable="d"
        Title="ACL-SIM 2.0" Height="703" Width="1000"
        Background="#1e1e1e" Foreground="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ACL-SIM 2.0" FontSize="20" FontWeight="SemiBold" />

        <!-- Center Controls Button -->
        <Button Content="Center Controls" Command="{Binding CenterControlsCommand}" 
                Width="140" Height="32" Margin="0,8,0,0" 
                HorizontalAlignment="Left" FontWeight="SemiBold">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#28a745"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCentering}" Value="True">
                            <Setter Property="Content" Value="Centering..."/>
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Background" Value="#6c757d"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- ProSim Connection Panel -->
        <Border Grid.Row="1" Background="#252525" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ProSim IP -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProSimIp}" VerticalAlignment="Center" Foreground="LightGray"/>
                    <TextBlock Text="ProSim IP:" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- ProSim Status -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="24,0,12,0">
                    <Ellipse Width="12" Height="12" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProSimConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="LimeGreen" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ProSimConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="Yellow" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ProSimConnectionState}" Value="Failed">
                                        <Setter Property="Fill" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ProSimStatusMessage}" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" Foreground="LightGray"/>
                </StackPanel>

                <!-- Connect Button -->
                <Button Grid.Column="3" Content="Connect" Command="{Binding ConnectProSimCommand}" Width="80" Height="28">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#007acc"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProSimConnectionState}" Value="Connected">
                                    <Setter Property="Content" Value="Disconnect"/>
                                    <Setter Property="Background" Value="#d13438"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProSimConnectionState}" Value="Connecting">
                                    <Setter Property="Content" Value="Connecting..."/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Background" Value="#555555"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="0,12,0,12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Axis panels bound to ViewModel -->
            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pitch" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Pitch.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White" />

                            <!-- ProSim Axis Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0" Visibility="{Binding Pitch.Enabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Prosim Axis:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PitchProSimAxis, StringFormat={}{0:F0}}" Width="32" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightBlue" />
                            </StackPanel>

                            <!-- Flight Control Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0" Visibility="{Binding Pitch.Enabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Flight Crl:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PitchFlightControl, StringFormat={}{0:F4}}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightGreen" />
                            </StackPanel>

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Pitch.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Autopilot (pitch only) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Pitch.AutopilotOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Auto Pilot" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Motor Moving -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Pitch.MotorIsMoving}" Value="True">
                                                    <Setter Property="Fill" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Moving" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Pitch.ConnectionBrush}" />
                                <TextBlock Text="RS485" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Pitch.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Pitch.EncoderNormalized}" IsEnabled="{Binding Pitch.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Pitch.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Torque:" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding Pitch.CurrentTorque, StringFormat={}{0:F1}, Mode=OneWay}" FontWeight="SemiBold" Foreground="#00D9FF" />
                            <Run Text=" (" />
                            <Run Text="{Binding Pitch.EncoderPercentage, StringFormat={}{0:F0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="LightGreen" />
                            <Run Text="% from center)" />
                        </TextBlock>
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Height="14" Value="{Binding Pitch.EncoderPercentage, Mode=OneWay}" IsEnabled="{Binding Pitch.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Pitch.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Pitch" IsEnabled="{Binding Pitch.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Roll" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Roll.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" Background="White" Foreground="White" />

                            <!-- ProSim Axis Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="Prosim Axis:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding RollProSimAxis, StringFormat={}{0:F2}}" Width="32" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightBlue" />
                            </StackPanel>

                            <!-- Flight Control Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="Flight Crl:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding RollFlightControl, StringFormat={}{0:F2}}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightGreen" />
                            </StackPanel>

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Roll.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Autopilot (roll only) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Roll.AutopilotOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Auto Pilot" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Motor Moving -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Roll.MotorIsMoving}" Value="True">
                                                    <Setter Property="Fill" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Moving" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Roll.ConnectionBrush}" />
                                <TextBlock Text="RS485" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Roll.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Roll.EncoderNormalized}" IsEnabled="{Binding Roll.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Roll.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Torque:" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding Roll.CurrentTorque, StringFormat={}{0:F1}, Mode=OneWay}" FontWeight="SemiBold" Foreground="#00D9FF" />
                            <Run Text=" (" />
                            <Run Text="{Binding Roll.EncoderPercentage, StringFormat={}{0:F0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="LightGreen" />
                            <Run Text="% from center)" />
                        </TextBlock>
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Height="14" Value="{Binding Roll.EncoderPercentage, Mode=OneWay}" IsEnabled="{Binding Roll.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Roll.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Roll" Click="Button_Click" IsEnabled="{Binding Roll.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Rudder" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Rudder.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White" />

                            <!-- ProSim Axis Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0" Visibility="{Binding Rudder.Enabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Prosim Axis:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding RudderProSimAxis, StringFormat={}{0:F2}}" Width="32" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightBlue" />
                            </StackPanel>

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Rudder.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Motor Moving -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Rudder.MotorIsMoving}" Value="True">
                                                    <Setter Property="Fill" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Moving" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Rudder.ConnectionBrush}" />
                                <TextBlock Text="RS485" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Rudder.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Rudder.EncoderNormalized}" IsEnabled="{Binding Rudder.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Rudder.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Torque:" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding Rudder.CurrentTorque, StringFormat={}{0:F1}, Mode=OneWay}" FontWeight="SemiBold" Foreground="#00D9FF" />
                            <Run Text=" (" />
                            <Run Text="{Binding Rudder.EncoderPercentage, StringFormat={}{0:F0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="LightGreen" />
                            <Run Text="% from center)" />
                        </TextBlock>
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Height="14" Value="{Binding Rudder.EncoderPercentage, Mode=OneWay}" IsEnabled="{Binding Rudder.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Rudder.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Rudder" IsEnabled="{Binding Rudder.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="8" Background="#252525" CornerRadius="6" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tiller" FontSize="16" FontWeight="Bold" Grid.Column="0" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <!-- Enable checkbox -->
                            <CheckBox IsChecked="{Binding Tiller.Enabled, Mode=TwoWay}" Content="Enable" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White" />

                            <!-- ProSim Axis Value -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="Prosim Axis:" Margin="0,0,4,0" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TillerProSimAxis, StringFormat={}{0:F2}}" Width="32" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="LightBlue" />
                            </StackPanel>

                            <!-- Hydraulics -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tiller.HydraulicsOn}" Value="True">
                                                    <Setter Property="Fill" Value="LimeGreen" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Hydraulics" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Motor Moving -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tiller.MotorIsMoving}" Value="True">
                                                    <Setter Property="Fill" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Moving" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Encoder connection status -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                <Ellipse Width="12" Height="12" Fill="{Binding Tiller.ConnectionBrush}" />
                                <TextBlock Text="RS485" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Encoder:" />
                        <TextBlock Text="{Binding Tiller.EncoderPosition, StringFormat={}{0:F0}}" Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="1" Height="14" Value="{Binding Tiller.EncoderNormalized}" IsEnabled="{Binding Tiller.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tiller.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Torque:" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding Tiller.CurrentTorque, StringFormat={}{0:F1}, Mode=OneWay}" FontWeight="SemiBold" Foreground="#00D9FF" />
                            <Run Text=" (" />
                            <Run Text="{Binding Tiller.EncoderPercentage, StringFormat={}{0:F0}, Mode=OneWay}" FontWeight="SemiBold" Foreground="LightGreen" />
                            <Run Text="% from center)" />
                        </TextBlock>
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Height="14" Value="{Binding Tiller.EncoderPercentage, Mode=OneWay}" IsEnabled="{Binding Tiller.Enabled}" Foreground="#FF00DFB6">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tiller.Enabled}" Value="False">
                                        <Setter Property="Value" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                        <Button Content="Setup" Command="{Binding SetupCommand}" CommandParameter="Tiller" IsEnabled="{Binding Tiller.Underlying.Settings.Enabled}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Global Settings" Width="140" Height="32" Margin="8,0,0,0" Command="{Binding GlobalSettingsCommand}" />
        </StackPanel>

        <!-- Error Log Area -->
        <Border Grid.Row="4" Background="#1a1a1a" CornerRadius="4" Padding="8" Margin="0,8,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="Error Log" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" />
                    <Button Content="Clear" FontSize="10" Padding="4,2" HorizontalAlignment="Right" Command="{Binding ClearErrorLogCommand}" />
                </Grid>
                <TextBox Text="{Binding ErrorLogText, Mode=OneWay}" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="10" 
                         Foreground="#ff6b6b" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Padding="0"
                         IsReadOnlyCaretVisible="True" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
